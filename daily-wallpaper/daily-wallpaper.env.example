# Copy to ~/.config/daily-wallpaper.env and customize.
#
# --- API keys (register and paste your own keys; do not use NASA DEMO_KEY for APOD) ---
#
# NASA (APOD): sign up and generate a key
#   https://api.nasa.gov/
#
# Unsplash (optional source "unsplash"): create an application → Access Key
#   https://unsplash.com/oauth/applications
#
# Comma-separated sources tried in deck order each run until one succeeds.
# Built-in ids: bing | apod | met | nasa_images | unsplash
# - apod: requires NASA_API_KEY (not DEMO_KEY).
# - unsplash: requires UNSPLASH_ACCESS_KEY.
# - bing, met, nasa_images: no keys.
DAILY_WALLPAPER_SOURCES=bing,apod,met,nasa_images,unsplash

NASA_API_KEY=your_nasa_api_key_here

# Optional — add "unsplash" to DAILY_WALLPAPER_SOURCES when set:
#UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# Met collection search (source "met"): free-text q= parameter
MET_SEARCH_QUERY=cars and engines

# Unsplash random photo (source "unsplash"): keyword query
UNSPLASH_QUERY=cars and engines

# Bing spotlight
BING_MKT=en-US
BING_IDX=0
BING_IMAGE_COUNT=8

# Prune saved files older than this many days (wp-* and legacy bing-*).
DAILY_WALLPAPER_KEEP_DAYS=7

# NASA Image Library (nasa_images): comma-separated search terms
#NASA_WALLPAPER_QUERIES=moon,mars,hubble,nebula
NASA_WALLPAPER_MAX_PAGE=10
NASA_WALLPAPER_SEARCH_ATTEMPTS=8
NASA_WALLPAPER_MIN_WIDTH=1920
NASA_WALLPAPER_MIN_HEIGHT=1080
